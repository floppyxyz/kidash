# Required: OpenAI API key for AI enrichment and icon generation
OPENAI_API_KEY=

# Required: Bearer token for write operations (POST/PATCH/DELETE)
# Generate one with: openssl rand -hex 32
AUTH_TOKEN=

# Optional: OpenAI model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Optional: SQLite database URL (default: file:./dev.db in dev, file:/data/kidash.db in docker)
DATABASE_URL=file:./dev.db

# Optional: Allow Google favicon service as fallback (default: disabled, privacy)
# When enabled, hostnames of your services are sent to Google
# ALLOW_GOOGLE_FAVICONS=true

# Optional: Enable background health check pinger (default: disabled)
# When enabled, the server pings all entry URLs every 5 minutes
# ENABLE_HEALTH_PINGER=true
